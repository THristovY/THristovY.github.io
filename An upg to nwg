import os
import json
from typing import List, Dict, Any
import requests

# ====================== CONFIG ======================
API_PROVIDER = "xai"  # Change to "openai" or "anthropic" if you prefer

if API_PROVIDER == "xai":
    API_URL = "https://api.x.ai/v1/chat/completions"
    API_KEY = os.getenv("XAI_API_KEY")          # Get from https://console.x.ai
    MODEL = "grok-4"                            # or grok-3, etc.

elif API_PROVIDER == "openai":
    API_URL = "https://api.openai.com/v1/chat/completions"
    API_KEY = os.getenv("OPENAI_API_KEY")
    MODEL = "gpt-4o"

else:  # anthropic
    API_URL = "https://api.anthropic.com/v1/messages"
    API_KEY = os.getenv("ANTHROPIC_API_KEY")
    MODEL = "claude-3-5-sonnet-20240620"

# ====================== TOOLS ======================
def web_search(query: str) -> str:
    """Example tool: Search the web"""
    # You can replace with Tavily, Serper, DuckDuckGo, etc.
    print(f"🔍 Searching web for: {query}")
    return f"Here are the top results for '{query}' (demo result)"

def calculate(expression: str) -> str:
    """Safe math calculator"""
    try:
        return str(eval(expression, {"__builtins__": {}}, {}))
    except:
        return "Invalid calculation"

TOOLS = {
    "web_search": web_search,
    "calculate": calculate,
}

TOOL_DEFINITIONS = [
    {
        "type": "function",
        "function": {
            "name": "web_search",
            "description": "Search the internet for up-to-date information",
            "parameters": {
                "type": "object",
                "properties": {"query": {"type": "string"}},
                "required": ["query"]
            }
        }
    },
    {
        "type": "function",
        "function": {
            "name": "calculate",
            "description": "Calculate mathematical expressions",
            "parameters": {
                "type": "object",
                "properties": {"expression": {"type": "string"}},
                "required": ["expression"]
            }
        }
    }
]

# ====================== AGENT CLASS ======================
class AIAgent:
    def __init__(self, system_prompt: str = None):
        self.messages = []
        if system_prompt:
            self.messages.append({"role": "system", "content": system_prompt})

    def _call_api(self, messages: List[Dict]) -> str:
        headers = {"Authorization": f"Bearer {API_KEY}"}
        
        if API_PROVIDER == "anthropic":
            payload = {
                "model": MODEL,
                "max_tokens": 1024,
                "messages": messages
            }
            headers["anthropic-version"] = "2023-06-01"
        else:
            payload = {
                "model": MODEL,
                "messages": messages,
                "tools": TOOL_DEFINITIONS,
                "tool_choice": "auto",
                "temperature": 0.7
            }

        response = requests.post(API_URL, json=payload, headers=headers)
        response.raise_for_status()
        data = response.json()

        if API_PROVIDER == "anthropic":
            return data["content"][0]["text"]
        else:
            return data["choices"][0]["message"]

    def run(self, user_query: str, max_steps: int = 10):
        self.messages.append({"role": "user", "content": user_query})
        
        for step in range(max_steps):
            print(f"\n🔄 Step {step+1} - Thinking...")
            
            response = self._call_api(self.messages)
            
            # Handle tool calls
            if hasattr(response, 'tool_calls') and response.tool_calls:
                self.messages.append(response)  # add assistant message with tool call
                
                for tool_call in response.tool_calls:
                    tool_name = tool_call.function.name
                    args = json.loads(tool_call.function.arguments)
                    
                    print(f"🛠️  Using tool: {tool_name}({args})")
                    
                    if tool_name in TOOLS:
                        result = TOOLS[tool_name](**args)
                        self.messages.append({
                            "role": "tool",
                            "tool_call_id": tool_call.id,
                            "name": tool_name,
                            "content": result
                        })
                    else:
                        self.messages.append({
                            "role": "tool",
                            "tool_call_id": tool_call.id,
                            "name": tool_name,
                            "content": "Tool not found"
                        })
            else:
                # Normal response (no tool needed)
                self.messages.append({"role": "assistant", "content": response.content})
                print(f"\n🤖 Agent: {response.content}")
                break

# ====================== USAGE ======================

if __name__ == "__main__":
    agent = AIAgent(system_prompt="""
        You are a helpful AI agent with access to tools.
        Think step by step. Use tools when needed.
        Be concise but thorough.
    """)
    
    while True:
        query = input("\nYou: ")
        if query.lower() in ["exit", "quit"]:
            break
        agent.run(query)
